# 导入所有依赖库：数值计算、数据处理、神经网络构建、数据归一化、绘图
import numpy as np
import pandas as np
import pandas as pd
from keras.models import Sequential
from keras.layers import Dense, SimpleRNN, LSTM
from sklearn.preprocessing import MinMaxScaler
import matplotlib.pyplot as plt

# 时序数据构建函数：将连续数据转换为RNN可接受的序列样本，slide为时间步长
def extract_data(data, slide):
    x, y = [], []
    # 遍历数据生成输入序列和对应标签
    for i in range(len(data) - slide):
        # 取slide长度数据作为输入特征
        x.append([a for a in data[i:i+slide]])
        # 取下一个数据作为预测目标
        y.append(data[i+slide])
    x = np.array(x)
    # 重塑为RNN输入格式：(样本数量, 时间步长, 特征维度)
    x = x.reshape(x.shape[0], x.shape[1], 1)
    return x, y

# 文本数据预处理函数：将字符序列转为独热编码，适配LSTM文本生成任务
def data_preprocessing(data, time_steps, features, char_to_int):
    x, y = [], []
    for i in range(len(data) - time_steps):
        seq = data[i:i+time_steps]
        # 字符转为one-hot向量
        x.append([np.eye(features)[char_to_int[c]] for c in seq])
        # 下一个字符作为标签
        y.append(char_to_int[data[i+time_steps]])
    return np.array(x), np.array(y)

# ==================== RNN股价预测任务 ====================
# 加载股票训练数据集
train = pd.read_csv('zgpa_train.csv')
# 提取收盘价作为预测目标
train_price = train[['close']].values
# 数据归一化到0-1区间，提升模型训练稳定性
scaler = MinMaxScaler(feature_range=(0,1))
train_norm = scaler.fit_transform(train_price)
# 构建时序样本，时间步长设为8
X_train, y_train = extract_data(train_norm, 8)

# 加载测试集并做相同预处理
test = pd.read_csv('zgpa_test.csv')
test_price = test[['close']].values
test_norm = scaler.transform(test_price)
X_test, y_test = extract_data(test_norm, 8)

# 构建SimpleRNN模型
model = Sequential()
# 添加RNN层：5个神经元，输入形状匹配样本格式，relu激活避免梯度消失
model.add(SimpleRNN(units=5, input_shape=(X_train.shape[1], X_train.shape[2]), activation='relu'))
# 输出层：1个神经元，线性激活用于回归预测
model.add(Dense(units=1, activation='linear'))
# 编译模型：Adam优化器，均方误差作为回归任务损失函数
model.compile(optimizer='adam', loss='mean_squared_error')
# 训练模型：50轮迭代，批次大小32
model.fit(X_train, y_train, epochs=50, batch_size=32)

# 测试集预测并还原真实股价
y_pred = model.predict(X_test)
y_pred = scaler.inverse_transform(y_pred)
y_real = scaler.inverse_transform(y_test.reshape(-1,1))

# 绘制真实股价与预测股价对比曲线
plt.plot(y_real, label='real price')
plt.plot(y_pred, label='predicted price')
plt.legend()
plt.show()

# 保存训练好的股价预测模型
model.save('rnn_stock.h5')

# ==================== LSTM文本生成任务 ====================
# 读取文本语料并去除换行符
raw_data = open('flare').read()
data = raw_data.replace('\n', ' ').replace('\r', '')
# 构建字符与数字的映射字典
letters = list(set(data))
int_to_char = {i: c for i, c in enumerate(letters)}
char_to_int = {c: i for i, c in enumerate(letters)}

# 设置文本序列时间步与字符特征数
time_steps = 20
features = len(letters)
# 预处理文本为模型输入格式
X, y = data_preprocessing(data, time_steps, features, char_to_int)

# 构建LSTM文本生成模型
model = Sequential()
# LSTM层：20个神经元，捕捉长距离文本依赖
model.add(LSTM(units=20, input_shape=(X.shape[1], X.shape[2])))
# 输出层：softmax激活输出字符概率分布
model.add(Dense(units=features, activation='softmax'))
# 编译模型：分类任务使用稀疏交叉熵损失
model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])
# 训练模型：100轮迭代，批次大小64
model.fit(X, y, epochs=100, batch_size=64)

# 保存文本生成模型
model.save('lstm_text.h5')
